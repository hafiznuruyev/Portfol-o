/*
create database Superstore;
use Superstore;

WITH Customer_RFM AS 
(
    -- Addım 1: Hər bir müştəri üçün R, F və M göstəricilərini hesablayırıq
    SELECT 
        [Customer ID],
        [Customer Name],
        -- Recency: Datanın ən son tarixindən müştərinin son alış-veriş tarixi arasındakı gün fərqi
        DATEDIFF(day, MAX([Order Date]), (SELECT MAX([Order Date]) FROM Orders)) AS Recency,
        -- Frequency: Unikal sifarişlərin sayı
        COUNT(DISTINCT [Order ID]) AS Frequency,
        -- Monetary: Ümumi satış məbləği
        SUM([Sales]) AS Monetary
    FROM Orders
    GROUP BY [Customer ID], [Customer Name]
),
RFM_Scores AS (
    -- Addım 2: NTILE(5) ilə müştərilərə 1-dən 5-ə qədər xal veririk
    SELECT 
        [Customer ID],
        [Customer Name],
        Recency, Frequency, Monetary,
        -- Recency üçün az gün keçən daha yaxşıdır (5 xal)
        NTILE(5) OVER (ORDER BY Recency ASC) AS R_Score,
        -- Frequency və Monetary üçün çox olan daha yaxşıdır (5 xal)
        NTILE(5) OVER (ORDER BY Frequency DESC) AS F_Score,
        NTILE(5) OVER (ORDER BY Monetary DESC) AS M_Score
    FROM Customer_RFM
)
-- Addım 3: Xalları birləşdirib yekun biznes seqmentini təyin edirik
SELECT 
    [Customer ID],
    [Customer Name],
    Recency AS [Son Alışdan Keçən Gün],
    Frequency AS [Sifariş Sayı],
    ROUND(Monetary, 2) AS [Toplam Qazanc],
    CONCAT(R_Score, F_Score, M_Score) AS RFM_Cell,
    CASE 
        WHEN R_Score >= 4 AND F_Score >= 4 AND M_Score >= 4 THEN 'Champions (Sadiq Müştərilər)'
        WHEN R_Score >= 3 AND F_Score >= 3 THEN 'Loyal Customers (Potensial Sadiqlər)'
        WHEN R_Score <= 2 AND F_Score >= 4 THEN 'Can''t Lose Them (İtirməməli Olduqlarımız)'
        WHEN R_Score <= 2 AND F_Score <= 2 THEN 'Lost (İtirilmiş Müştərilər)'
        ELSE 'Regular (Adi Müştərilər)'
    END AS [Biznes Seqmenti]
FROM RFM_Scores
ORDER BY [Toplam Qazanc] DESC;


SELECT 
    ROUND(SUM(Sales), 2) AS [Toplam Satış],
    ROUND(SUM(Profit), 2) AS [Toplam Gəlir],
    COUNT(DISTINCT [Order ID]) AS [Toplam Sifariş Sayı],
    ROUND(AVG(Discount) * 100, 2) AS [Ortalama Endirim %]
FROM Orders;

                                                                                    ----Ümumi Biznes KPI-ları (Satış, Gəlir, Sifariş Sayı)

SELECT TOP 10
    [Product ID],
    [Product Name],
    [Category],
    ROUND(SUM(Sales), 2) AS [Toplam Satış],
    ROUND(SUM(Profit), 2) AS [Toplam Gəlir]
FROM Orders
GROUP BY [Product ID], [Product Name], [Category]
ORDER BY [Toplam Satış] DESC;
                                                                                ----Ən çox satılan məhsulların siyahısı (Top 10)


SELECT 
    [Region],
    [State/Province],
    ROUND(SUM(Sales), 2) AS [Toplam Satış],
    ROUND(SUM(Profit), 2) AS [Toplam Gəlir],
    -- Gəlir marjası % (Profit Margin)
    ROUND((SUM(Profit) / SUM(Sales)) * 100, 2) AS [Gəlir Marjası %]
FROM Orders
GROUP BY [Region], [State/Province]
ORDER BY [Gəlir Marjası %] DESC;
                                                                            -----Ən gəlirli bölgələr və dövlətlər (Region və State/Province üzrə)

SELECT 
    [Category],
    [Sub-Category],
    ROUND(SUM(Sales), 2) AS [Toplam Satış],
    ROUND(SUM(Profit), 2) AS [Toplam Zərər]
FROM Orders
GROUP BY [Category], [Sub-Category]
-- HAVING qruplaşmadan sonra gəlir çıxan nəticəni filtrləyir
HAVING SUM(Profit) < 0
ORDER BY [Toplam Zərər] ASC; -- Ən çox zərər edən ən üstdə görünəcək

                                                                    -----Ən çox zərər edən məhsul kateqoriyaları və alt-kateqoriyalar (Category və Sub-Category üzrə)

SELECT 
    [Ship Mode],
    COUNT([Order ID]) AS [Sifariş Sayı],
    -- Sifariş tarixi ilə Göndərilmə tarixi arasındakı gün fərqinin ortalaması
    AVG(DATEDIFF(day, [Order Date], [Ship Date])) AS [Ortalama Çatdırılma Günü]
FROM Orders
GROUP BY [Ship Mode]
ORDER BY [Ortalama Çatdırılma Günü] ASC;



SELECT 
    MusteriTipi AS [Müştəri Kateqoriyası],
    COUNT([Customer ID]) AS [Müştəri Sayı],
    ROUND(SUM(ToplamXerc), 2) AS [Ümumi Satış],
    ROUND(AVG(ToplamXerc), 2) AS [Müştəri Başına Ortalama Xərc]
FROM (
    -- Subquery: Hər müştərinin toplam sifarişini və xərcini tapırıq
    SELECT 
        [Customer ID],
        COUNT(DISTINCT [Order ID]) AS SifarisSayi,
        SUM(Sales) AS ToplamXerc,
        CASE 
            WHEN COUNT(DISTINCT [Order ID]) >= 13 THEN 'VIP (Çox Aktiv)'
            WHEN COUNT(DISTINCT [Order ID]) BETWEEN 5 AND 12 THEN 'Daimi Müştəri'
            ELSE 'Az Aktiv / Yeni Müştəri'
        END AS MusteriTipi
    FROM Orders
    GROUP BY [Customer ID]
) AS MusteriAnalizi
GROUP BY MusteriTipi
ORDER BY [Ümumi Satış] DESC; 
                                                                    -----Müştəri kateqoriyalarına görə ümumi satış və müştəri başına ortalama xərc (VIP, Daimi, Az Aktiv/New Customer)

SELECT 
    YEAR([Order Date]) AS [İl],
    'R' + DATENAME(quarter, [Order Date]) AS [Rüb],
    COUNT(DISTINCT [Order ID]) AS [Toplam Sifariş],
    ROUND(SUM(Sales), 2) AS [Toplam Satış],
    ROUND(SUM(Profit), 2) AS [Toplam Gəlir]
FROM Orders
GROUP BY YEAR([Order Date]), 'R' + DATENAME(quarter, [Order Date])
ORDER BY [İl] ASC, [Rüb] ASC;
                                                                ----İllik və rüblük satış və gəlir analizi (Yearly and Quarterly Sales & Profit Analysis)

SELECT 
    [Region],
    [Sub-Category],
    ROUND(SUM(Sales), 2) AS [Toplam Satış],
    ROUND(SUM(Profit), 2) AS [Toplam Mənfəət],
    -- Satışın gəlirə çevrilmə effektivliyi
    ROUND((SUM(Profit) / SUM(Sales)) * 100, 2) AS [Profit Margin %]
FROM Orders
GROUP BY [Region], [Sub-Category]
-- Mənfəəti yüksək olan və marjası 15%-dən çox olanları gətiririk
HAVING SUM(Profit) > 0 AND (SUM(Profit) / SUM(Sales)) * 100 > 15
ORDER BY [Region] ASC, [Toplam Mənfəət] DESC;
                                                    -----------------Ən yüksək gəlir və marja ilə bölgə və alt-kateqoriyalar (Region və Sub-Category üzrə)

WITH MonthlySales AS (
    -- Addım 1: Hər il və ay üzrə toplam satışı hesablayırıq
    SELECT 
        YEAR([Order Date]) AS SalesYear,
        MONTH([Order Date]) AS SalesMonth,
        SUM(Sales) AS CurrentMonthSales
    FROM Orders
    GROUP BY YEAR([Order Date]), MONTH([Order Date])
),
LaggedSales AS (
    -- Addım 2: LAG funksiyası ilə keçmiş ayın məlumatını gətiririk
    SELECT 
        SalesYear,
        SalesMonth,
        CurrentMonthSales,
        LAG(CurrentMonthSales, 1) OVER (ORDER BY SalesYear, SalesMonth) AS PreviousMonthSales
    FROM MonthlySales
)
-- Addım 3: İki ay arasındakı faiz fərqini hesablayırıq
SELECT 
    SalesYear AS [İl],
    SalesMonth AS [Ay],
    ROUND(CurrentMonthSales, 2) AS [Cari Ay Satış],
    ROUND(PreviousMonthSales, 2) AS [Əvvəlki Ay Satış],
    ROUND(((CurrentMonthSales - PreviousMonthSales) / NULLIF(PreviousMonthSales, 0)) * 100, 2) AS [MoM Growth %]
FROM LaggedSales
ORDER BY [İl] ASC, [Ay] ASC;
                                                                -----Aylıq satış artımını hesablamaq üçün LAG funksiyasından istifadə (Month-over-Month Growth Analysis)


WITH CustomerRanking AS (
    -- Addım 1: Müştərilərin regionlar üzrə toplam satşını tapıb sıralayırıq
    SELECT 
        [Region],
        [Customer ID],
        [Customer Name],
        ROUND(SUM(Sales), 2) AS [Toplam Alış-Veriş],
        DENSE_RANK() OVER (PARTITION BY [Region] ORDER BY SUM(Sales) DESC) AS SiraNo
    FROM Orders
    GROUP BY [Region], [Customer ID], [Customer Name]
)
-- Addım 2: Hər regiondan yalnız ilk 3 müştərini filtrləyirik
SELECT 
    [Region],
    SiraNo AS [Region Daxili Reytinq],
    [Customer ID],
    [Customer Name],
    [Toplam Alış-Veriş]
FROM CustomerRanking
WHERE SiraNo <= 3
ORDER BY [Region] ASC, SiraNo ASC;
                                                ------------------Hər regionun ən yaxşı 3 müştərisini tapmaq üçün DENSE_RANK funksiyasından istifadə (Top 3 Customers by Region)

*/
WITH DailySales AS (
    -- Addım 1: Gündəlik ümumi satışları tapırıq (2025-ci il nümunəsində)
    SELECT 
        [Order Date],
        SUM(Sales) AS DailyTotal
    FROM Orders
    WHERE YEAR([Order Date]) = 2025 -- İstədiyin ili qoya bilərsən
    GROUP BY [Order Date]
)
-- Addım 2: Window funksiyası ilə üst-üstə toplayaraq gedirik (Running Total)
SELECT 
    [Order Date],
    ROUND(DailyTotal, 2) AS [Günlük Satış],
    ROUND(SUM(DailyTotal) OVER (ORDER BY [Order Date] ), 2) AS [Kumulyativ Toplam (YTD)]
FROM DailySales
ORDER BY [Order Date] ASC;
